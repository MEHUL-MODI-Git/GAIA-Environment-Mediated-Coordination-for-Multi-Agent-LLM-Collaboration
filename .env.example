# GAIA API keys — copy this file to `.env` and fill in real values.
# NEVER commit or submit the real `.env` (it contains live secrets).

# Required for almost all experiments (default provider, gpt-4.1-nano/gpt-4.1)
OPENAI_API_KEY=

# Required only for: C5-xmodel, NX2 cross-vendor Claude judge
ANTHROPIC_API_KEY=

# Required only for: NX3-open (open-weight Llama), C3-7 steering
GROQ_API_KEY=
